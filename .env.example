# Django
SECRET_KEY=cambiar-en-produccion-minimo-50-caracteres-aleatorios
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Producción: DEBUG=False, ALLOWED_HOSTS=tu-dominio.com,tu-ip-ec2
# Producción: CORS_ALLOWED_ORIGINS=https://tu-dominio.com
# Producción: SECURE_SSL_REDIRECT=True (solo cuando HTTPS esté activo en nginx)
# Producción: DJANGO_SETTINGS_MODULE=config.settings.production (lo define docker-compose.prod.yml)

# PostgreSQL
POSTGRES_DB=hab_db
POSTGRES_USER=hab_user
POSTGRES_PASSWORD=hab_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hab_user:hab_password@db:5432/hab_db

# Redis — producción requiere password
REDIS_PASSWORD=hab_redis_password
REDIS_URL=redis://:hab_redis_password@redis:6379/0
CELERY_BROKER_URL=redis://:hab_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:hab_redis_password@redis:6379/1

# WhatsApp Meta API
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_WEBHOOK_VERIFY_TOKEN=hab-webhook-token
META_APP_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# AWS S3 — producción (dejar AWS_S3_ENDPOINT_URL vacío para S3 real)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hab-docs-prod
AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=   # solo para MinIO en desarrollo local

# Frontend build (producción)
VITE_API_URL=/api/v1

# Email
