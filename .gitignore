# --- Secrets & environment ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
*.manifest
*.spec

# Virtual environments
.venv/
venv/
env/
ENV/

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# --- Testing & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# --- Linters & type checkers ---
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# --- Celery ---
celerybeat-schedule
celerybeat.pid

# --- Playwright ---
playwright-report/
test-results/
.playwright/

# --- Node / Frontend ---
node_modules/
frontend/dist/
frontend/.vite/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# --- Docker ---
docker-compose.override.yml
*.override.yml

# --- SSL / keys (nunca commitear) ---
*.pem
*.key
*.crt
*.p12
secrets/

# --- IDE & OS ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

